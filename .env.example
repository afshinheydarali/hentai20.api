BOT_TOKEN=your_telegram_bot_token

# Optional: comma-separated Telegram numeric user IDs allowed to use the bot.
# Leave empty to allow everyone.
ALLOWED_USER_IDS=

# Optional: Telegram bot upload limit in MB. Normal bots are usually limited to about 50 MB.
MAX_TELEGRAM_FILE_MB=45

# Optional: if ZIP is too large for Telegram, bot will send this API download URL instead.
# Example: https://your-domain.com
PUBLIC_BASE_URL=
