BOT_TOKEN=your_telegram_bot_token
ALLOWED_USER_IDS=123456789
MAX_TELEGRAM_FILE_MB=45
PUBLIC_BASE_URL=
DEFAULT_PAGE=1
DEFAULT_SEARCH_LIMIT=10
MAX_CHAPTERS_PER_ALL=10
CHAPTERS_PER_PAGE=20
HOST=0.0.0.0
PORT=8000

# Google Drive upload settings
# Recommended for Railway: paste the full service-account JSON as one line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional alternative for local runs only:
# GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

# Optional parent folder ID. If empty, manga folders are created in the service account Drive root.
# Recommended: create a folder in your Google Drive, share it with the service account email, and paste its ID here.
GDRIVE_ROOT_FOLDER_ID=

# 1 means uploaded ZIPs get an anyone-with-link reader permission. 0 keeps them private.
GDRIVE_MAKE_PUBLIC=1
